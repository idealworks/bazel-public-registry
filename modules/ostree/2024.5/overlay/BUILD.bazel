    "src/libostree/ostree-version.h",
]

ENUM_TYPES = [
    "src/libostree/ostree-fetcher.h",
]

cc_library(
    name = "bupsplit",
    srcs = [
        "src/libostree/bupsplit.c",
    ],
    hdrs = [
        "src/libostree/bupsplit.h",
    ],
    includes = [
        "src/libostree",
    ],
    visibility = ["//visibility:private"],
)

genrule(
    name = "generate_ostree_enumtypes_h",
    srcs = ["src/libostree/ostree-enumtypes.h.template"] + ENUM_TYPES,
    outs = ["src/libostree/ostree-enumtypes.h"],
    tools = ["@glib//gobject:glib_mkenums"],
    cmd = "$(location @glib//gobject:glib_mkenums) --template $(location src/libostree/ostree-enumtypes.h.template) $(locations src/libostree/ostree-fetcher.h) > $@.tmp && mv $@.tmp $@",
)

genrule(
    name = "generate_ostree_enumtypes_c",
    srcs = [
        "src/libostree/ostree-enumtypes.c.template",
        ":generate_ostree_enumtypes_h",
    ] + ENUM_TYPES,
    outs = ["src/libostree/ostree-enumtypes.c"],
    tools = ["@glib//gobject:glib_mkenums"],
    cmd = "$(location @glib//gobject:glib_mkenums) --template $(location src/libostree/ostree-enumtypes.c.template) $(locations src/libostree/ostree-fetcher.h) > $@.tmp && mv $@.tmp $@",
)

filegroup(
    name = "ostree_enumtypes",
    srcs = [
        "src/libostree/ostree-enumtypes.h",
        "src/libostree/ostree-enumtypes.c",
    ],
)

