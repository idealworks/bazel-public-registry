OSTREE_FETCHER_COMMON_SRCS = [
    "src/libostree/ostree-fetcher-util.c",
    "src/libostree/ostree-fetcher-uri.c",
    "src/libostree/ostree-metalink.c",
]

genrule(
    name = "generate_ostree_version_h",
    outs = ["src/libostree/ostree-version.h"],
    cmd = """
cat > $@ <<'EOF'
#pragma once
#define OSTREE_VERSION "2024.5"
#define OSTREE_VERSION_MAJOR 2024
#define OSTREE_VERSION_MINOR 5
#define OSTREE_VERSION_MICRO 0
EOF
""",
)

LIBOTCORE_HEADERS = glob(
    ["src/libotcore/*.h"],
)
LIBOTUTIL_HEADERS = glob(
    ["src/libotutil/*.h"],
)
SWITCHROOT_HEADERS = glob(
    ["src/switchroot/*.h"],
)

LIBOSTREE_PRIVATE_HEADERS = glob(
    ["src/libostree/*.h"],
    exclude = LIBOSTREE_PUBLIC_HEADERS + LIBOSTREE_PUBLIC_BUILT_HEADERS,
)


cc_library(
    name = "ostree",
    srcs = (
        OSTREE_SRCS
        + [":generate_ostree_enumtypes_c"] + OSTREE_LIBARCHIVE_SRCS + OSTREE_FETCHER_CURL_SRCS
    ),
    hdrs = LIBOSTREE_PUBLIC_HEADERS + [
        ":generate_ostree_enumtypes_h",
        ":generate_ostree_version_h",
        # ":generate_config_h",
    ]+ LIBOTUTIL_HEADERS+LIBOTCORE_HEADERS+ SWITCHROOT_HEADERS,
    textual_hdrs = LIBOSTREE_PRIVATE_HEADERS,
    includes = [
        "src/libostree",
        "src/libotutil",
        "src/libotcore",
        "src/switchroot",
    ],
    copts = [
        "-fvisibility=hidden",
        "-D_OSTREE_PUBLIC=__attribute__((visibility(\\\"default\\\")))",
        "-D_GNU_SOURCE",
        "-DSHORTENED_SYSCONFDIR=\\\"etc\\\"",
        "-DSYSCONFDIR=\\\"/etc\\\"",
        "-DDATADIR=\\\"/usr/share\\\"",
        "-DLIBEXECDIR=\\\"/usr/libexec\\\"",
        "-DLOCALEDIR=\\\"/usr/share/locale\\\"",
        "-DTARGET_PREFIX=\\\"/usr\\\"",
        "-DG_LOG_DOMAIN=\\\"OSTree\\\"",
        "-DGRUB2_MKCONFIG_PATH=\\\"grub2-mkconfig\\\"",
        "-DOSTREE_COMPILATION",
        "-DPKGLIBEXECDIR=\\\"/usr/libexec\\\"",
        "-DHAVE_CURL=1",
        "-DHAVE_LIBARCHIVE=1",
        "-DPACKAGE_NAME=\\\"ostree\\\"",
        "-DPACKAGE_VERSION=\\\"2024.5\\\"",
    ],
    deps = [
        "@libglnx//:libglnx",
        "@bsdiff//:bsdiff_lib",
        "@glib//glib:glib",
        "@glib//gio:gio",
        ":bupsplit",
        "@curl",
        "@libarchive//libarchive:archive",
    ],
)
