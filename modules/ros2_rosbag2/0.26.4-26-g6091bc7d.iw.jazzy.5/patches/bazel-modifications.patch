+void CircularMessageCache::push_transient_local(
+  std::shared_ptr<const rosbag2_storage::SerializedBagMessage> msg)
+{
+  PublisherGid gid;
+  std::copy(
+    msg->publisher_gid.data, msg->publisher_gid.data + RMW_GID_STORAGE_SIZE, gid.begin());
+
+  std::lock_guard<std::mutex> lock(transient_local_mutex_);
+  // Keep only the latest message per {topic, publisher} (KeepLast(1) latch semantics).
+  transient_local_messages_[TransientLocalKey{msg->topic_name, gid}] = msg;
+}
+
+void CircularMessageCache::inject_transient_local_messages()
+{
+  std::lock_guard<std::mutex> lock(transient_local_mutex_);
+  if (transient_local_messages_.empty()) {
+    return;
+  }
+
+  // Buffer is in receive order, so front() carries the earliest recv_timestamp = window start.
+  const bool have_window_start = !consumer_buffer_->empty();
+  const rcutils_time_point_value_t window_start_time =
+    have_window_start ? consumer_buffer_->front()->recv_timestamp : 0;
+
+  for (const auto & kv : transient_local_messages_) {
+    const auto & stored = kv.second;
+    auto injected = std::make_shared<rosbag2_storage::SerializedBagMessage>(*stored);
+    if (have_window_start) {
+      // Clamp up to the window start: latched values from before the window (e.g. /tf_static)
+      // get pulled forward so they are present from the first frame, while ones (re)published
+      // inside the window keep their true time so playback shows the real transition.
+      injected->recv_timestamp = std::max(stored->recv_timestamp, window_start_time);
+    }
+    consumer_buffer_->push_preserved_front(injected);
+  }
+}
