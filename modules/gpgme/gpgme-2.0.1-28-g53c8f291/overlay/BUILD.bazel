        "src/progress.c",
        "src/queryswdb.c",
        "src/revsig.c",
        "src/setexpire.c",
        "src/setownertrust.c",
        "src/sig-notation.c",
        "src/sign.c",
        "src/signers.c",
        "src/spawn.c",
        "src/status-table.c",
        "src/tofupolicy.c",
        "src/verify.c",
        "src/version.c",
        "src/vfs-create.c",
        "src/vfs-mount.c",
        "src/wait.c",
        "src/wait-global.c",
        "src/wait-private.c",
        "src/wait-user.c",
